-- ─────────────────────────────────────────────────────────────────────
--  TOOL — build spider-drone + wire up events
-- ─────────────────────────────────────────────────────────────────────
local toolEquipped = false

local function buildTool()
    pcall(function()
        local old = LP.Backpack:FindFirstChild("Mel's Portal Gun")
            or (LP.Character and LP.Character:FindFirstChild("Mel's Portal Gun"))
        if old then old:Destroy() end
    end)

    local tool = buildPortalGunModel({
        blueColor   = CFG.blueColor,
        orangeColor = CFG.orangeColor,
    })

    tool.Equipped:Connect(function()   toolEquipped = true  end)
    tool.Unequipped:Connect(function() toolEquipped = false end)
    tool.Activated:Connect(function()  placePortal("blue")  end)

    -- ── Kill the built-in "tool holding" animations ──────────────────
    -- THIS is the actual reason every Holding Style looked identical:
    -- Roblox's default per-character Animate script detects any
    -- equipped Tool and immediately plays its own baked-in tool-hold
    -- animations ("toolnone"/"toolslash"/"toollunge"/"toolidle" —
    -- Roblox's stock one-hand-reaching-forward pose). Those tracks
    -- re-assert their own Motor6D Transform on every single physics
    -- step, so no matter what our RenderStepped code calculated for
    -- HOLD_POSES, the stock animation kept winning the very next tick
    -- and stomping it back to that one generic one-handed pose — which
    -- is exactly the "always looks like the same one hand default"
    -- symptom. Our custom pose code was never actually broken; it was
    -- being overwritten in real time by an animation we never stopped.
    -- Fix: while this tool is held, continuously zero the weight of
    -- any currently-playing tool-related AnimationTrack so nothing but
    -- our own script drives the arm joints. Leg/torso walk & idle
    -- animations are untouched — only tracks whose animation/track name
    -- matches Roblox's known tool-animation naming are muted.
    local TOOL_ANIM_KEYWORDS = { "tool", "slash", "lunge" }
    local function isToolAnimTrack(track)
        local nm = ((track.Name or "") .. " " .. (track.Animation and track.Animation.Name or "")):lower()
        for _, kw in ipairs(TOOL_ANIM_KEYWORDS) do
            if nm:find(kw, 1, true) then return true end
        end
        return false
    end
    safeSpawn(function()
        local char = LP.Character or LP.CharacterAdded:Wait()
        local hum  = char:WaitForChild("Humanoid")
        local animator = hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator", 3)
        if not animator then return end
        RunService.Heartbeat:Connect(function()
            if not toolEquipped then return end
            local ok, tracks = pcall(function() return animator:GetPlayingAnimationTracks() end)
            if not ok or not tracks then return end
            for _, track in ipairs(tracks) do
                local matched, isTool = pcall(isToolAnimTrack, track)
                if matched and isTool then
                    pcall(function()
                        if track.WeightTarget ~= 0 then
                            track:AdjustWeight(0, 0.05)
                        end
                    end)
                end
            end
        end)
    end)

    -- Collect all blue/orange neon parts for refreshPortalVisuals
    _modelParts.blueNeon   = {}
    _modelParts.orangeNeon = {}
    for _, part in ipairs(tool:GetDescendants()) do
        if part:IsA("BasePart") and part.Material == Enum.Material.Neon then
            -- Heuristic: parts brighter toward blue vs orange
            local col = part.Color
            local blueScore   = col.B - col.R
            local orangeScore = col.R - col.B
            if orangeScore > 0.25 then
                table.insert(_modelParts.orangeNeon, part)
            elseif blueScore > 0.10 then
                table.insert(_modelParts.blueNeon, part)
            end
        end
    end

    -- Idle glow pulse on the emitter
    local emitter = tool:FindFirstChild("Emitter", true)
    if emitter then
        -- Color emitter tip to track selected portal color each frame
        RunService.RenderStepped:Connect(function()
            if not (emitter and emitter.Parent) then return end
            local col = selColor == "blue" and CFG.blueColor or CFG.orangeColor
            pcall(function() emitter.Color = col end)
            local eCore = tool:FindFirstChild("EmitterCore", true)
            if eCore then
                pcall(function()
                    eCore.Color = Color3.new(
                        math.min(1, col.R + 0.45),
                        math.min(1, col.G + 0.45),
                        math.min(1, col.B + 0.45))
                end)
            end
            local eLight = emitter:FindFirstChildOfClass("PointLight")
            if eLight then pcall(function() eLight.Color = col end) end
        end)
        pcall(function() VFX.startIdlePulse(emitter) end)
    end


    -- ── Smooth two-handed arm animation ──────────────────────────────
    -- Injected from MelPortalGun_Mobile: smooth lerp, idle sway, both arms.
    safeSpawn(function()
        local char = LP.Character or LP.CharacterAdded:Wait()
        local hum  = char:WaitForChild("Humanoid")
        local swayT = 0
        local mouse = LP:GetMouse()

        if hum.RigType == Enum.HumanoidRigType.R15 then
            local HRP           = char:WaitForChild("HumanoidRootPart")
            local RightUpperArm = char:WaitForChild("RightUpperArm")
            local LeftUpperArm  = char:WaitForChild("LeftUpperArm")
            local RightShoulder = RightUpperArm:WaitForChild("RightShoulder")
            local LeftShoulder  = LeftUpperArm:WaitForChild("LeftShoulder")

            -- Optional forearm/hand joints — present on the default R15
            -- rig but guarded with FindFirstChild since some custom
            -- avatars strip them. These are what actually let the
            -- support hand curl toward the gun instead of just the
            -- shoulder tilting a little; without bending these two,
            -- every Holding Style reads as "one hand near the gun".
            local LeftLowerArm = char:FindFirstChild("LeftLowerArm")
            local LeftHand     = char:FindFirstChild("LeftHand")
            local LeftElbow    = LeftLowerArm and LeftLowerArm:FindFirstChild("LeftElbow")
            local LeftWrist    = LeftHand and LeftHand:FindFirstChild("LeftWrist")

            -- Head-look: R15 previously never turned its head toward the
            -- aim point (only R6 did, via its Neck join). Adding this
            -- brings both rigs to parity and makes every Holding Style
            -- read as a deliberate, eyes-on-target hold rather than a
            -- character staring blankly forward while its arms aim.
            local Head = char:FindFirstChild("Head")
            local Neck = Head and Head:FindFirstChild("Neck")
            local defNeck = Neck and Neck.Transform
            local curNeck = defNeck

            local defRight = RightShoulder.Transform
            local defLeft  = LeftShoulder.Transform
            local defElbow = LeftElbow and LeftElbow.Transform
            local defWrist = LeftWrist and LeftWrist.Transform
            local curRight = defRight
            local curLeft  = defLeft
            local curElbow = defElbow
            local curWrist = defWrist
            local lastHoldMode = CFG.holdMode

            RunService.RenderStepped:Connect(function(dt)
                swayT   = swayT + dt
                recoilT = math.max(0, recoilT - dt)
                local recoilProgress = recoilDur > 0 and (1 - recoilT / recoilDur) or 1
                local recoilStr = evalRecoilCurve(CFG.shootMode, recoilProgress)

                -- Detect a live Holding Style change and play the quick
                -- regrip flourish instead of silently snapping next frame.
                if CFG.holdMode ~= lastHoldMode then
                    lastHoldMode = CFG.holdMode
                    triggerRegrip()
                end

                if reloadActive then
                    -- ── Reload animation (R15) ───────────────────────
                    reloadProgress = reloadProgress + dt
                    local p = reloadProgress / RELOAD_DUR  -- 0 → 1

                    if p >= 1 then
                        reloadActive   = false
                        reloadProgress = 0
                    else
                        local rootCF = HRP.CFrame
                        local fwd    = rootCF.LookVector
                        local rotOff = (rootCF - rootCF.Position):Inverse()

                        local drop, swing, raise
                        if p < 0.25 then
                            -- Phase 1: both arms drop to waist
                            drop  = easeInOut(p / 0.25) * -0.75
                            swing = 0; raise = 0
                        elseif p < 0.5 then
                            -- Phase 2: left arm swings inward (magazine gesture)
                            drop  = -0.75
                            swing = easeInOut((p - 0.25) / 0.25)
                            raise = 0
                        elseif p < 0.75 then
                            -- Phase 3: arms rise back up
                            local t = easeInOut((p - 0.5) / 0.25)
                            drop  = -0.75 * (1 - t)
                            swing = 1 - t; raise = 0
                        else
                            -- Phase 4: snap to aim (handled by normal aim code next frame)
                            drop = 0; swing = 0; raise = 0
                        end

                        local targetRight = rotOff
                            * CFrame.new(Vector3.new(), fwd * 5000)
                            * CFrame.Angles(math.pi / 2 + drop, 0, 0)
                        local targetLeft = rotOff
                            * CFrame.new(Vector3.new(), fwd * 5000)
                            * CFrame.Angles(math.pi / 2 + drop - 0.18 - swing * 0.55, -swing * 1.1, 0.22)

                        local alpha = math.min(1, dt * 18)
                        curRight = curRight:Lerp(targetRight, alpha)
                        curLeft  = curLeft:Lerp(targetLeft,  alpha)
                        RightShoulder.Transform = curRight
                        LeftShoulder.Transform  = curLeft
                    end

                elseif regripActive then
                    -- ── Regrip flourish (R15) ────────────────────────
                    -- Instant feedback that the Holding Style actually
                    -- changed: both arms flick through the new style's
                    -- regripPitch/regripRoll shape and settle straight
                    -- into the newly-selected pose.
                    regripProgress = regripProgress + dt
                    local p = regripProgress / REGRIP_DUR
                    if p >= 1 then
                        regripActive = false; regripProgress = 0
                    else
                        local pose = HOLD_POSES[CFG.holdMode] or HOLD_POSES.TwoHanded
                        local dir = (mouse.Hit.Position - HRP.Position)
                        if dir.Magnitude > 0.01 then
                            dir = dir.Unit
                            local rootCF = HRP.CFrame
                            local rotOff = (rootCF - rootCF.Position):Inverse()
                            local kick = math.sin(p * math.pi) * -1
                            local targetRight = rotOff
                                * CFrame.new(Vector3.new(), dir * 5000)
                                * CFrame.Angles(math.pi / 2 + kick * pose.regripPitch, 0, kick * pose.regripRoll)
                            local targetLeft = rotOff
                                * CFrame.new(Vector3.new(), dir * 5000)
                                * CFrame.Angles(math.pi / 2 + pose.leftPitch + kick * pose.regripPitch * 0.7, 0, pose.leftRoll + kick * pose.regripRoll * 0.7)
                            local alpha = math.min(1, dt * 20)
                            curRight = curRight:Lerp(targetRight, alpha)
                            RightShoulder.Transform = curRight
                            if pose.oneHanded then
                                curLeft = curLeft:Lerp(defLeft, alpha)
                            else
                                curLeft = curLeft:Lerp(targetLeft, alpha)
                            end
                            LeftShoulder.Transform = curLeft
                        end
                    end

                elseif pumpActive then
                    -- ── Pump-cycle flourish (R15) ────────────────────
                    -- Plays once, right after the recoil kick, only for the
                    -- PumpCycle shooting style: the gun arm racks sharply
                    -- back then snaps forward again like working a slide.
                    pumpProgress = pumpProgress + dt
                    local p = pumpProgress / PUMP_DUR
                    if p >= 1 then
                        pumpActive = false; pumpProgress = 0
                    else
                        local dir = (mouse.Hit.Position - HRP.Position)
                        if dir.Magnitude > 0.01 then
                            dir = dir.Unit
                            local rootCF = HRP.CFrame
                            local rotOff = (rootCF - rootCF.Position):Inverse()
                            local notch = math.sin(p * math.pi) * -0.55
                            local targetRight = rotOff
                                * CFrame.new(Vector3.new(), dir * 5000)
                                * CFrame.Angles(math.pi / 2 + notch, 0, 0)
                            local targetLeft = rotOff
                                * CFrame.new(Vector3.new(), dir * 5000)
                                * CFrame.Angles(math.pi / 2 - 0.18 + notch * 0.6, 0, 0.22)
                            local alpha = math.min(1, dt * 16)
                            curRight = curRight:Lerp(targetRight, alpha)
                            curLeft  = curLeft:Lerp(targetLeft,  alpha)
                            RightShoulder.Transform = curRight
                            LeftShoulder.Transform  = curLeft
                        end
                    end

                elseif toolEquipped then
                    -- ── Normal aim + recoil (R15) ────────────────────
                    local pose = HOLD_POSES[CFG.holdMode] or HOLD_POSES.TwoHanded
                    local smNow = SHOOT_MODES[CFG.shootMode] or SHOOT_MODES.SnapKick
                    local dir = (mouse.Hit.Position - HRP.Position)
                    if dir.Magnitude < 0.01 then return end
                    dir = dir.Unit
                    local rootCF = HRP.CFrame
                    local rotOff = (rootCF - rootCF.Position):Inverse()
                    -- Idle breathing overlay: a slow sway layered on top
                    -- of the base aim sway, sized per Holding Style so a
                    -- tucked shoulder-hold reads steadier than a loose
                    -- hip-carry.
                    local breathT = swayT * (pose.breathSpeed or 1)
                    local breathX = math.sin(breathT * 0.9)  * (pose.breathAmp or 0.01)
                    local breathY = math.cos(breathT * 0.6)  * (pose.breathAmp or 0.01) * 0.6
                    -- Walk-bob: while the character is actually moving, a
                    -- light footstep-synced bob is layered on top too, so
                    -- the held gun doesn't look perfectly welded in place
                    -- while running — scaled down for tucked/steady styles.
                    local planarSpeed = Vector3.new(hum.MoveDirection.X, 0, hum.MoveDirection.Z).Magnitude * hum.WalkSpeed
                    local bobT  = swayT * (planarSpeed > 0.5 and 6.5 or 0)
                    local bobAmt = planarSpeed > 0.5 and math.min(1, planarSpeed / (hum.WalkSpeed > 0 and hum.WalkSpeed or 16)) or 0
                    local bobX  = math.sin(bobT) * 0.014 * bobAmt * (1 - (pose.breathSpeed and math.min(pose.breathSpeed, 1) or 0) * 0.3)
                    local swayX  = math.sin(swayT * 1.1) * 0.018 + breathX + bobX
                    local swayY  = math.sin(swayT * 0.7) * 0.012 + breathY
                    local recoilPitch = recoilStr * -0.45 * recoilMul
                    local recoilRoll  = recoilStr *  0.12 * recoilMul
                    local recoilYaw   = recoilStr * (smNow.yawKick or 0) * recoilMul * recoilYawSign
                    local targetRight = rotOff
                        * CFrame.new(Vector3.new(), dir * 5000)
                        * CFrame.Angles(math.pi / 2 + swayX + recoilPitch + pose.rightPitch, swayY + (pose.rightYaw or 0) + recoilYaw, -recoilRoll + (pose.rightRoll or 0))
                    local alpha = math.min(1, dt * 14)
                    curRight = curRight:Lerp(targetRight, alpha)
                    RightShoulder.Transform = curRight
                    if pose.oneHanded then
                        -- Pistol-style: off-hand rests instead of gripping,
                        -- and the forearm/hand joints relax fully too so
                        -- there's no lingering "reaching" pose.
                        local relaxAlpha = math.min(1, dt * 10)
                        curLeft = curLeft:Lerp(defLeft, relaxAlpha)
                        LeftShoulder.Transform = curLeft
                        if LeftElbow and defElbow then
                            curElbow = curElbow:Lerp(defElbow, relaxAlpha)
                            LeftElbow.Transform = curElbow
                        end
                        if LeftWrist and defWrist then
                            curWrist = curWrist:Lerp(defWrist, relaxAlpha)
                            LeftWrist.Transform = curWrist
                        end
                    else
                        local targetLeft = rotOff
                            * CFrame.new(Vector3.new(), dir * 5000)
                            * CFrame.Angles(math.pi / 2 + swayX + pose.leftPitch + recoilPitch, -swayY, pose.leftRoll + recoilRoll)
                        curLeft = curLeft:Lerp(targetLeft, alpha)
                        LeftShoulder.Transform = curLeft
                        -- Bend the forearm + hand toward the gun's grip so
                        -- the support hand visually wraps it — this is the
                        -- part that actually sells "two-handed" instead of
                        -- just tilting the upper arm a little.
                        if LeftElbow and defElbow then
                            local elbowTarget = CFrame.Angles((pose.elbowBend or 0) + recoilPitch * 0.3, 0, 0)
                            curElbow = curElbow:Lerp(elbowTarget, alpha)
                            LeftElbow.Transform = curElbow
                        end
                        if LeftWrist and defWrist then
                            local wristTarget = CFrame.Angles((pose.wristBend or 0), 0, (pose.wristRoll or 0))
                            curWrist = curWrist:Lerp(wristTarget, alpha)
                            LeftWrist.Transform = curWrist
                        end
                    end
                    if Neck and defNeck then
                        -- Turn the head slightly toward the aim point —
                        -- capped well short of the full arm rotation so it
                        -- reads as "glancing down the sights", not a
                        -- cartoonish full head-snap.
                        local headPitch = math.clamp((dir.Y) * 0.6, -0.35, 0.35)
                        local neckTarget = CFrame.Angles(headPitch, 0, 0)
                        curNeck = curNeck:Lerp(neckTarget, math.min(1, dt * 10))
                        Neck.Transform = curNeck
                    end
                else
                    -- ── Return to default pose ───────────────────────
                    local alpha = math.min(1, dt * 10)
                    curRight = curRight:Lerp(defRight, alpha)
                    curLeft  = curLeft:Lerp(defLeft,  alpha)
                    RightShoulder.Transform = curRight
                    LeftShoulder.Transform  = curLeft
                    if Neck and defNeck then
                        curNeck = curNeck:Lerp(defNeck, alpha)
                        Neck.Transform = curNeck
                    end
                    if LeftElbow and defElbow then
                        curElbow = curElbow:Lerp(defElbow, alpha)
                        LeftElbow.Transform = curElbow
                    end
                    if LeftWrist and defWrist then
                        curWrist = curWrist:Lerp(defWrist, alpha)
                        LeftWrist.Transform = curWrist
                    end
                end
            end)

        else
            -- R6: both shoulders + neck track aim with idle sway
            local torso      = char:WaitForChild("Torso")
            local origRightS = torso:WaitForChild("Right Shoulder").C0
            local origLeftS  = torso:WaitForChild("Left Shoulder").C0
            local origNeck   = torso:WaitForChild("Neck").C0
            local lastHoldMode = CFG.holdMode

            RunService.RenderStepped:Connect(function(dt)
                swayT   = swayT + dt
                recoilT = math.max(0, recoilT - dt)
                local recoilProgress = recoilDur > 0 and (1 - recoilT / recoilDur) or 1
                local recoilStr = evalRecoilCurve(CFG.shootMode, recoilProgress)
                if not torso.Parent then return end

                local tRS = torso:FindFirstChild("Right Shoulder")
                local tLS = torso:FindFirstChild("Left Shoulder")
                local tN  = torso:FindFirstChild("Neck")

                if CFG.holdMode ~= lastHoldMode then
                    lastHoldMode = CFG.holdMode
                    triggerRegrip()
                end

                if reloadActive then
                    -- ── Reload animation (R6) ────────────────────────
                    reloadProgress = reloadProgress + dt
                    local p = reloadProgress / RELOAD_DUR

                    if p >= 1 then
                        reloadActive   = false
                        reloadProgress = 0
                    else
                        local drop, swing
                        if p < 0.25 then
                            drop = easeInOut(p / 0.25) * -0.7; swing = 0
                        elseif p < 0.5 then
                            drop = -0.7; swing = easeInOut((p - 0.25) / 0.25)
                        elseif p < 0.75 then
                            local t = easeInOut((p - 0.5) / 0.25)
                            drop = -0.7 * (1 - t); swing = 1 - t
                        else
                            drop = 0; swing = 0
                        end
                        local alpha = math.min(1, dt * 18)
                        if tRS then tRS.C0 = tRS.C0:Lerp(CFrame.new(1, .65, 0) * CFrame.Angles(drop, 1.55, 0), alpha) end
                        if tLS then tLS.C0 = tLS.C0:Lerp(CFrame.new(-1, .60, 0) * CFrame.Angles(drop - swing * 0.55, -1.55 - swing * 0.8, 0), alpha) end
                        if tN  then tN.C0  = tN.C0:Lerp(origNeck, 0.12) end
                    end

                elseif regripActive then
                    -- ── Regrip flourish (R6) ─────────────────────────
                    regripProgress = regripProgress + dt
                    local p = regripProgress / REGRIP_DUR
                    if p >= 1 then
                        regripActive = false; regripProgress = 0
                    else
                        local pose = HOLD_POSES[CFG.holdMode] or HOLD_POSES.TwoHanded
                        local kick = math.sin(p * math.pi) * -1
                        local alpha = math.min(1, dt * 20)
                        if tRS then tRS.C0 = tRS.C0:Lerp(CFrame.new(1, .65, 0) * CFrame.Angles(kick * pose.regripPitch, 1.55, kick * pose.regripRoll), alpha) end
                        if tLS then
                            if pose.oneHanded then
                                tLS.C0 = tLS.C0:Lerp(origLeftS, alpha)
                            else
                                local off = pose.leftOffset or Vector3.new()
                                tLS.C0 = tLS.C0:Lerp(CFrame.new(-1 + off.X, .60 + off.Y, off.Z) * CFrame.Angles(pose.leftPitch + kick * pose.regripPitch * 0.7, -1.55, pose.leftRoll + kick * pose.regripRoll * 0.7), alpha)
                            end
                        end
                    end

                elseif pumpActive then
                    -- ── Pump-cycle flourish (R6) ─────────────────────
                    pumpProgress = pumpProgress + dt
                    local p = pumpProgress / PUMP_DUR
                    if p >= 1 then
                        pumpActive = false; pumpProgress = 0
                    else
                        local notch = math.sin(p * math.pi) * -0.55
                        local alpha = math.min(1, dt * 16)
                        if tRS then tRS.C0 = tRS.C0:Lerp(CFrame.new(1, .65, 0) * CFrame.Angles(notch, 1.55, 0), alpha) end
                        if tLS then tLS.C0 = tLS.C0:Lerp(CFrame.new(-1, .60, 0) * CFrame.Angles(notch * 0.6 - 0.15, -1.55, 0), alpha) end
                    end

                elseif toolEquipped then
                    -- ── Normal aim + recoil (R6) ─────────────────────
                    -- R6 has no separate forearm bone, so distinct Holding
                    -- Styles are sold two ways: the usual aim-angle offsets
                    -- PLUS a `leftOffset` translation that physically moves
                    -- the whole shoulder socket closer to (or further from)
                    -- the gun, approximating the R15 elbow/wrist bend.
                    local pose = HOLD_POSES[CFG.holdMode] or HOLD_POSES.TwoHanded
                    local smNow = SHOOT_MODES[CFG.shootMode] or SHOOT_MODES.SnapKick
                    local rawDir = (mouse.Hit.Position - mouse.Origin.Position)
                    local pitchY = rawDir.Magnitude > 0.01
                        and -math.asin(math.clamp(rawDir.Unit.Y, -1, 1)) or 0
                    local breathT = swayT * (pose.breathSpeed or 1)
                    local breathX = math.sin(breathT * 0.9) * (pose.breathAmp or 0.01)
                    local breathY = math.cos(breathT * 0.6) * (pose.breathAmp or 0.01) * 0.6
                    local planarSpeed = Vector3.new(hum.MoveDirection.X, 0, hum.MoveDirection.Z).Magnitude * hum.WalkSpeed
                    local bobT   = swayT * (planarSpeed > 0.5 and 6.5 or 0)
                    local bobAmt = planarSpeed > 0.5 and math.min(1, planarSpeed / (hum.WalkSpeed > 0 and hum.WalkSpeed or 16)) or 0
                    local bobX   = math.sin(bobT) * 0.014 * bobAmt
                    local swayX = math.sin(swayT * 1.1) * 0.02 + breathX + bobX
                    local swayY = math.sin(swayT * 0.7) * 0.012 + breathY
                    local recoilPitch = recoilStr * -0.4 * recoilMul
                    local recoilYaw   = recoilStr * (smNow.yawKick or 0) * recoilMul * recoilYawSign
                    local alpha = math.min(1, dt * 12)
                    if tRS then tRS.C0 = tRS.C0:Lerp(CFrame.new(1, .65, 0) * CFrame.Angles(pitchY + swayX + recoilPitch + pose.rightPitch, 1.55 + (pose.rightYaw or 0) + recoilYaw, swayY - recoilStr * 0.1 * recoilMul + (pose.rightRoll or 0)), alpha) end
                    if pose.oneHanded then
                        if tLS then tLS.C0 = tLS.C0:Lerp(origLeftS, math.min(1, dt * 10)) end
                    else
                        local off = pose.leftOffset or Vector3.new()
                        if tLS then tLS.C0 = tLS.C0:Lerp(CFrame.new(-1 + off.X, .60 + off.Y, off.Z) * CFrame.Angles(pitchY + swayX + pose.leftPitch + recoilPitch, -1.55, pose.leftRoll - swayY + recoilStr * 0.1 * recoilMul), alpha) end
                    end
                    if tN  then tN.C0  = tN.C0:Lerp(CFrame.new(0, 1, 0) * CFrame.Angles(pitchY + 1.55 + swayX * 0.5, 3.15, 0), 0.18) end
                else
                    -- ── Return to default ────────────────────────────
                    local alpha = math.min(1, dt * 10)
                    if tRS then tRS.C0 = tRS.C0:Lerp(origRightS, alpha) end
                    if tLS then tLS.C0 = tLS.C0:Lerp(origLeftS,  alpha) end
                    if tN  then tN.C0  = tN.C0:Lerp(origNeck,    alpha) end
                end
            end)
        end
    end)

    tool.Parent = LP.Backpack
    return tool
end

