-- A labeled row with ◀ / ▶ buttons that cycles through a fixed list of
-- named options (e.g. hold or shoot styles) — same visual language as
-- makeToggle, just for settings with more than two states.
local function makeCycleRow(parent, label, options, getV, setV)
    local row = Instance.new("Frame"); row.Size = UDim2.new(1,0,0,42)
    row.BackgroundColor3 = Color3.fromRGB(20,20,38); row.BorderSizePixel = 0; row.ZIndex = 32; row.Parent = parent
    corner(row, UDim.new(0,8))
    local lbl = makeLabel(row, label, 12, Color3.fromRGB(210,210,230), Enum.Font.Gotham, Enum.TextXAlignment.Left, 33)
    lbl.Size = UDim2.new(0.4,0,1,0); lbl.Position = UDim2.new(0,10,0,0)
    local valLbl = makeLabel(row, "", 12, Color3.fromRGB(140,210,255), Enum.Font.GothamBold, Enum.TextXAlignment.Center, 33)
    valLbl.Size = UDim2.new(0,118,1,0); valLbl.Position = UDim2.new(1,-156,0,0)
    local prevBtn = makeBtn(row, "◀", Color3.fromRGB(45,45,75), UDim2.new(1,-188,0.5,-13), UDim2.new(0,26,0,26), 33)
    corner(prevBtn, UDim.new(0,6))
    local nextBtn = makeBtn(row, "▶", Color3.fromRGB(45,45,75), UDim2.new(1,-34,0.5,-13), UDim2.new(0,26,0,26), 33)
    corner(nextBtn, UDim.new(0,6))
    local idx = 1
    local curV = getV()
    for i, opt in ipairs(options) do if opt.id == curV then idx = i end end
    local function refresh()
        valLbl.Text = options[idx].name
        setV(options[idx].id)
    end
    refresh()
    prevBtn.MouseButton1Click:Connect(function()
        idx = idx - 1; if idx < 1 then idx = #options end; refresh()
    end)
    nextBtn.MouseButton1Click:Connect(function()
        idx = idx + 1; if idx > #options then idx = 1 end; refresh()
    end)
end

