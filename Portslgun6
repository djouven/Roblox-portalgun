-- Cartoon-style squash-and-stretch on the player model right at the moment
-- they exit a portal, using the Humanoid's BodyDepthScale/BodyHeightScale.
function VFX.squashStretch(hrp)
    if not hrp then return end
    local char = hrp.Parent
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    local heightScale = humanoid:FindFirstChild("BodyHeightScale")
    local depthScale  = humanoid:FindFirstChild("BodyDepthScale")
    local widthScale  = humanoid:FindFirstChild("BodyWidthScale")
    if not (heightScale and depthScale and widthScale) then return end
    local baseH, baseD, baseW = heightScale.Value, depthScale.Value, widthScale.Value
    pcall(function()
        heightScale.Value = baseH * 0.78
        depthScale.Value  = baseD * 1.18
        widthScale.Value  = baseW * 1.18
    end)
    safeDelay(0.06, function()
        pcall(function()
            heightScale.Value = baseH * 1.10
            depthScale.Value  = baseD * 0.92
            widthScale.Value  = baseW * 0.92
        end)
        safeDelay(0.12, function()
            pcall(function()
                heightScale.Value = baseH
                depthScale.Value  = baseD
                widthScale.Value  = baseW
            end)
        end)
    end)
end

