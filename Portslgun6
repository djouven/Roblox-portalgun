        placePortal("orange")
    elseif ut == Enum.UserInputType.Gamepad1 then
        if kc == Enum.KeyCode.ButtonR2 then placePortal("blue")
        elseif kc == Enum.KeyCode.ButtonL2 then placePortal("orange")
        elseif kc == Enum.KeyCode.ButtonB  then closePortals()
        end
