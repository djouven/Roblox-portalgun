-- ═════════════════════════════════════════════════════════════════════
--  HOLD & SHOOT ANIMATION PACK III
--  ───────────────────────────────────────────────────────────────────
--  This section defines every data-driven knob behind the "Holding
--  Style" and "Shooting Animation" selectors in Settings → Advanced.
--  Nothing here is hardcoded per-rig — R15 and R6 both read the same
--  HOLD_POSES / SHOOT_MODES tables and interpret whichever fields
--  apply to their skeleton (R15 additionally bends the elbow + wrist
--  so the support hand visually wraps the gun; R6 has no forearm
--  bone, so it approximates the same read with a shoulder-position
--  offset instead).
-- ═════════════════════════════════════════════════════════════════════

-- ── Holding styles ──────────────────────────────────────────────────
-- Each entry describes the FULL support-arm pose, not just a shoulder
-- tilt, so switching styles produces a genuinely different silhouette:
--   rightPitch/rightYaw/rightRoll  — gun (right) arm aim offset
--   leftPitch/leftRoll             — left shoulder aim offset
--   elbowBend, wristBend, wristRoll
--       — R15-only: bends LeftLowerArm + LeftHand so the support hand
--         actually curls toward the gun's foregrip instead of just
--         drifting near it. This is what was missing before: rotating
--         the shoulder alone never brought the hand close enough to
--         read as "gripping" the weapon, so every style looked like
--         the same one-handed hold.
--   leftOffset (Vector3)
--       — R6-only: since R6's arm is a single rigid part with no
--         elbow, we fake the same "hand closer to the gun" read by
--         translating the whole shoulder socket toward the barrel.
--   breathAmp / breathSpeed
--       — subtle idle sway added on top of the aim pose so a held
--         gun never looks perfectly frozen, tuned per style (a tucked
--         shoulder-hold breathes less than a loose hip-carry).
--   regripPitch / regripRoll
--       — the shape of the quick "flourish" both arms play for an
--         instant whenever the player switches Holding Style, so the
--         change is felt, not just quietly applied next frame.
--   oneHanded — true drops the support arm to its resting idle pose
--         entirely (pistol-style single-hand hold).
local HOLD_POSES = {
    -- Rifle-style two-hand grip: support hand curls forward onto an
    -- imaginary foregrip, mirroring the gun arm's aim. This is the
    -- long-standing default and now the most visually "two-handed" of
    -- the four styles.
    TwoHanded = {
        rightPitch = 0,     rightYaw = 0,    rightRoll = 0,
        leftPitch  = -0.18, leftRoll = 0.22,
        elbowBend  = -1.48, wristBend = -0.34, wristRoll = 0.22,
        leftOffset = Vector3.new(0, 0, 0),
        breathAmp  = 0.010, breathSpeed = 1.0,
        regripPitch = 0.30, regripRoll = -0.12,
        oneHanded  = false,
    },
    -- Pistol-style: only the gun arm aims, the off-hand drops fully to
    -- its idle resting pose — no elbow/wrist bend applied at all.
    OneHanded = {
        rightPitch = 0.05,  rightYaw = 0,    rightRoll = 0.04,
        leftPitch  = 0,     leftRoll = 0,
        elbowBend  = 0,     wristBend = 0,     wristRoll = 0,
        leftOffset = Vector3.new(0, 0, 0),
        breathAmp  = 0.016, breathSpeed = 1.25,
        regripPitch = 0.18, regripRoll = 0.08,
        oneHanded  = true,
    },
    -- Low/hip-ready: gun angled down and out, casual carry between
    -- shots, support hand loosely cupping underneath rather than
    -- wrapped around the top.
    Hip = {
        rightPitch = 0.55,  rightYaw = 0.10, rightRoll = -0.06,
        leftPitch  = -0.55, leftRoll = 0.16,
        elbowBend  = -0.92, wristBend = -0.14, wristRoll = 0.10,
        leftOffset = Vector3.new(0, -0.12, -0.30),
        breathAmp  = 0.022, breathSpeed = 0.75,
        regripPitch = 0.42, regripRoll = -0.20,
        oneHanded  = false,
    },
    -- Shoulder-tucked: both arms pulled in tight to the body for a
    -- steadier, more deliberate "aimed-in" look — the tightest, most
    -- controlled two-handed grip of the set.
    Shoulder = {
        rightPitch = -0.12, rightYaw = -0.05, rightRoll = 0.03,
        leftPitch  = -0.10, leftRoll = 0.10,
        elbowBend  = -1.62, wristBend = -0.46, wristRoll = 0.26,
        leftOffset = Vector3.new(0.14, 0.05, -0.10),
        breathAmp  = 0.006, breathSpeed = 1.4,
        regripPitch = 0.22, regripRoll = -0.08,
        oneHanded  = false,
    },
}

-- ── Shooting styles ──────────────────────────────────────────────────
-- Every shot kicks the arms back for `dur` seconds along a named
-- `curve` (see evalRecoilCurve below) so different styles don't just
-- differ in magnitude, they differ in *shape* — a snappy flick reads
-- nothing like a slow heavy punch even at the same strength.
--   dur         — seconds the recoil kick lasts
--   strength    — overall multiplier on kick angle, camera shake, and
--                 muzzle flash size
--   curve       — name of the easing shape evalRecoilCurve() applies
--   pump        — chains the extra rack-the-slide flourish afterward
--   shakeFreq   — camera-shake oscillation speed multiplier
--   pitchVar    — +/- random pitch variance applied to the fire sound
--                 so repeated shots don't sound like the same sample
--                 looping (small, natural-feeling per-shot variety)
--   yawKick — small horizontal (left/right) kick added on top of the
--             usual up/down recoil, so the gun doesn't just punch
--             straight back — it torques slightly sideways too, with
--             the direction alternating per portal color (blue kicks
--             one way, orange the other) for natural-feeling variety
--             between shots rather than a perfectly symmetric recoil.
local SHOOT_MODES = {
    SnapKick   = { dur = 0.22, strength = 1.00, curve = "snap",  pump = false, shakeFreq = 1.0, pitchVar = 0.04, yawKick = 0.030 },
    HeavyPunch = { dur = 0.34, strength = 1.65, curve = "punch", pump = false, shakeFreq = 0.7, pitchVar = 0.03, yawKick = 0.100 },
    PumpCycle  = { dur = 0.20, strength = 1.05, curve = "pump",  pump = true,  shakeFreq = 1.1, pitchVar = 0.05, yawKick = 0.050 },
    Quickdraw  = { dur = 0.11, strength = 0.55, curve = "quick", pump = false, shakeFreq = 1.6, pitchVar = 0.06, yawKick = 0.015 },
}

-- Sign of the current shot's horizontal recoil kick (-1 or 1), set in
-- placePortal() from which portal color was just fired so the two
-- colors torque the gun in opposite directions instead of identically.
local recoilYawSign = 1

-- Per-style recoil easing. `t` runs 0 (the instant a shot fires) → 1
-- (fully settled back to the aim pose). Returns a 0..1 strength
-- multiplier — callers still apply SHOOT_MODES[..].strength on top.
local function evalRecoilCurve(styleName, t)
    t = math.clamp(t, 0, 1)
    if styleName == "HeavyPunch" then
        -- Slow, heavy decay with a small secondary rebound near the
        -- end, like the arm settling after absorbing real weight.
        local base   = (1 - t) ^ 1.6
        local rebound = math.sin(t * math.pi * 2.2) * 0.09 * (1 - t)
        return math.clamp(base + rebound, 0, 1)
    elseif styleName == "Quickdraw" then
        -- Barely-there flick, gone almost instantly.
        return (1 - t) ^ 3.4
    elseif styleName == "PumpCycle" then
        -- Sharp kick that hands off cleanly into the rack flourish.
        return (1 - t) ^ 2.0
    else -- "snap" / SnapKick / fallback
        return (1 - t) ^ 2.4
    end
end

local function triggerReload()
    if reloadActive or not toolEquipped then return end
    reloadActive   = true
    reloadProgress = 0
end

local function triggerPumpCycle()
    if pumpActive or not toolEquipped then return end
    pumpActive   = true
    pumpProgress = 0
end

-- Regrip is the quick, subtle flourish both arms play for an instant
-- whenever CFG.holdMode changes at runtime, so switching Holding
-- Style in Settings feels like an intentional re-grip of the weapon
-- rather than an invisible snap on the next frame.
local regripActive   = false
local regripProgress = 0
local REGRIP_DUR     = 0.22

local function triggerRegrip()
    if not toolEquipped then return end
    regripActive   = true
    regripProgress = 0
end

local function easeInOut(t)
    t = math.clamp(t, 0, 1)
    return t < 0.5 and 2*t*t or -1 + (4 - 2*t)*t
end

local function easeOutBack(t)
    t = math.clamp(t, 0, 1)
    local c1 = 1.70158
    local c3 = c1 + 1
    return 1 + c3 * (t - 1) ^ 3 + c1 * (t - 1) ^ 2
end

local function placePortal(color)
    if not gunEnabled then return end
    if fireCooldown then return end
    local hrp = getHRP(); if not hrp then return end

    local sm = SHOOT_MODES[CFG.shootMode] or SHOOT_MODES.SnapKick
    recoilT   = sm.dur
    recoilDur = sm.dur
    recoilMul = sm.strength
    recoilYawSign = (color == "orange") and 1 or -1
    if sm.pump then safeDelay(sm.dur, triggerPumpCycle) end
    local pitchVar = sm.pitchVar or 0
    playSound(CFG.sndFire, hrp, 1 + (math.random() * 2 - 1) * pitchVar)
    local result = doRaycast()
    if not result or not isValidSurface(result) then return end

    fireCooldown = true; safeDelay(0.15, function() fireCooldown = false end)

    local cf = portalCF(result)
    if portals[color] then
        local old = portals[color]; portals[color] = nil
        if CFG.vfxDrainSwirl then pcall(function() VFX.energyDrainSwirl(old, color) end) end
        playSound(CFG.sndClose, old.part); animateClose(old)
        pcall(function() VFX.onPortalClose(old, color) end)
    end
    local d = makePortalPart(color)
    d.cf = cf; portals[color] = d
    animateOpen(d, cf); playSound(CFG.sndCreate, d.part)
    pcall(function() VFX.onPortalOpen(d, cf, color) end)
    pcall(function() VFX.muzzleFlash(color) end)
    pcall(function() VFX.impactScorch(result, color) end)
    pcall(function() VFX.spawnBeamTrail(hrp.Position, result.Position, color, {width = 0.25, fadeTime = 0.3}) end)

    if CFG.vfxLightning   then pcall(function() VFX.lightningArcs(d, color) end) end
    if CFG.vfxEmbers      then pcall(function() VFX.emberShower(cf, color) end) end
    if CFG.vfxShockwave   then pcall(function() VFX.shockwaveGround(result.Position, color) end) end
    if CFG.vfxTendrils    then pcall(function() VFX.energyTendrils(d, color) end) end
    if CFG.vfxStarburst   then pcall(function() VFX.starburst(result.Position, color) end) end
    if CFG.vfxGlyphs      then pcall(function() VFX.glyphRing(d, color) end) end
    if CFG.vfxHaze        then pcall(function() VFX.distortionHaze(d) end) end
    if CFG.vfxWindGust    then pcall(function() VFX.portalWindGust(d, color) end) end
    if CFG.vfxRimArcs     then pcall(function() VFX.rimLightning(d, color) end) end
    if CFG.vfxVortexLoop  then pcall(function() VFX.vortexSwirlLoop(d, color) end) end
    if CFG.vfxColorCycle  then pcall(function() VFX.colorCycleAura(d) end) end
    if CFG.vfxFloatMotes  then pcall(function() VFX.floatingSparkMotes(d, color) end) end
    if CFG.vfxCrackDecals then pcall(function() VFX.impactCrackDecals(result, color) end) end
    if CFG.vfxCoronaFlare then pcall(function() VFX.portalCoronaFlare(cf, color) end) end
    if CFG.vfxScorchRing  then pcall(function() VFX.groundScorchRing(result.Position, color) end) end
    if CFG.vfxFireflies   then pcall(function() VFX.ambientFireflies(d, color) end) end
    if CFG.vfxVignette    then pcall(function() VFX.screenVignettePulse(color) end) end
    if CFG.vfxRipple      then pcall(function() VFX.rippleField(cf, color) end) end
    if CFG.vfxBeamPillar  then pcall(function() VFX.energyBeamPillar(cf, color) end) end

    if CFG.vfxMuzzleShockRing then pcall(function() VFX.muzzleShockRing(result, color) end) end
    if CFG.vfxIrisOpen        then pcall(function() VFX.irisOpen(d, cf, color) end) end
    if CFG.vfxSpiralRings     then pcall(function() VFX.spiralRings(cf, color) end) end
    if CFG.vfxPortalBreathe   then pcall(function() VFX.portalBreathe(d, color) end) end
    if CFG.vfxOrbitalSparks   then pcall(function() VFX.orbitalSparks(d, color) end) end
    if CFG.vfxPortalWobble    then pcall(function() VFX.portalWobble(d, cf) end) end

    if CFG.vfxPulseCascade  then pcall(function() VFX.pulseRingCascade(cf, color) end) end
    if CFG.vfxRotatingRunes then pcall(function() VFX.rotatingRunes(d, color) end) end
    if CFG.vfxPortalFlicker then pcall(function() VFX.portalFlicker(d) end) end
    if CFG.vfxPulseWave     then pcall(function() VFX.portalPulseWave(cf, color) end) end
    if CFG.vfxGrowIn        then pcall(function() VFX.growIn(d, cf) end) end
    if CFG.vfxHeatShimmer   then pcall(function() VFX.heatShimmer(d, cf, color) end) end
    if CFG.vfxEyeBlink      then pcall(function() VFX.portalEyeBlink(d) end) end

    local otherColor = color == "blue" and "orange" or "blue"
    if CFG.vfxChainReaction and portals[otherColor] then
        pcall(function() VFX.chainReactionPulse(cf, portals[otherColor].cf, color) end)
    end

    if CFG.vfxRingSpin    then pcall(function() VFX.portalRingSpin(d, cf) end) end
    if CFG.vfxDebrisOrbit then pcall(function() VFX.floatingDebrisOrbit(d, color) end) end
    if CFG.vfxShakeRipple then pcall(function() VFX.cameraShakeRipple(0.15 * recoilMul * (sm.shakeFreq or 1)) end) end
    if CFG.vfxColorBleed  then pcall(function() VFX.portalColorBleed(d, color) end) end
end

