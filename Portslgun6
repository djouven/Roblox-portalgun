-- ─────────────────────────────────────────────────────────────────────────
--  HOOK: SHOOTING MODES
--  placePortal is a local upvalue in this script scope — rebinding it here
--  updates all closures (including input callbacks) that reference it.
-- ─────────────────────────────────────────────────────────────────────────
local _origPlace = placePortal
placePortal = function(color)
    local m = MODES[curMode] and MODES[curMode].name or "Standard"

    if m == "Rapid" then
        local sv = CFG.cooldown
        CFG.cooldown = 0.15
        _origPlace(color)
        safeDelay(0.01, function() CFG.cooldown = sv end)

    elseif m == "Dual" then
        _origPlace("blue")
        safeDelay(0.05, function() _origPlace("orange") end)

    elseif m == "Chain" then
        _origPlace(color)
        local other = (color == "blue") and "orange" or "blue"
        safeDelay(0.3, function() _origPlace(other) end)

    elseif m == "Scatter" then
        _origPlace(color)
        safeDelay(0.08, function() _origPlace(color) end)
        safeDelay(0.16, function() _origPlace(color) end)

    elseif m == "Ghost" or m == "Bounce" then
        local sv = CFG.ghostSurfaces
        CFG.ghostSurfaces = true
        _origPlace(color)
        safeDelay(0.01, function() CFG.ghostSurfaces = sv end)

    else
        -- Standard / Charge / anything else
        _origPlace(color)
    end
end

-- ─────────────────────────────────────────────────────────────────────────
--  HOOK: TELEPORT POWERS
--  teleportPlayer is likewise a local upvalue.
-- ─────────────────────────────────────────────────────────────────────────
local _origTele = teleportPlayer
teleportPlayer = function(fromData, toData)
    _origTele(fromData, toData)

    local pw = POWERS[curPower] and POWERS[curPower].name or "Normal"
    if pw == "Normal" then return end

    local hrp = getHRP()
    if not hrp then return end

    safeSpawn(function()
        if pw == "SpeedDash" then
            local dir = hrp.CFrame.LookVector
            pcall(function() hrp.AssemblyLinearVelocity = dir * 110 end)

        elseif pw == "GravFlip" then
            local mass = 10
            pcall(function() mass = hrp.AssemblyMass end)
            local bf = Instance.new("BodyForce")
            bf.Force = Vector3.new(0, Workspace.Gravity * 2.2 * mass, 0)
            bf.Parent = hrp
            safeWait(1.5)
            pcall(function() bf:Destroy() end)

        elseif pw == "SonicBoom" then
            local b = Instance.new("Part")
            b.Anchored = true; b.CanCollide = false; b.CanTouch = false
            b.Material = Enum.Material.Neon; b.Color = CFG.orangeColor
            b.Shape = Enum.PartType.Ball
            b.Size = Vector3.new(1, 1, 1); b.Transparency = 0.15
            b.CFrame = hrp.CFrame; b.Parent = Workspace
            tw(b, 0.55, { Size = Vector3.new(22, 22, 22), Transparency = 1 })
            safeDelay(0.7, function() pcall(function() b:Destroy() end) end)

        elseif pw == "Clone" then
            local d = Instance.new("Part")
            d.Anchored = true; d.CanCollide = false; d.CanTouch = false
            d.Material = Enum.Material.Neon; d.Color = CFG.blueColor
            d.Size = Vector3.new(2, 5, 1); d.Transparency = 0.45
            d.CFrame = CFrame.new(hrp.Position - hrp.CFrame.LookVector * 3)
            d.Parent = Workspace
            safeWait(2.5)
            tw(d, 0.5, { Transparency = 1 })
            safeDelay(0.6, function() pcall(function() d:Destroy() end) end)

        elseif pw == "PhaseShift" then
            local hum = hrp.Parent and hrp.Parent:FindFirstChildOfClass("Humanoid")
            if hum then
                local sv = hum.WalkSpeed
                pcall(function() hum.WalkSpeed = sv * 2.2 end)
                safeWait(2)
                pcall(function() hum.WalkSpeed = sv end)
            end

        elseif pw == "WarpStorm" then
            for i = 1, 4 do
                local ox = (math.random() - 0.5) * 28
                local oz = (math.random() - 0.5) * 28
                local p = Instance.new("Part")
                p.Anchored = true; p.CanCollide = false; p.CanTouch = false
                p.Material = Enum.Material.Neon
                p.Color = (i % 2 == 0) and CFG.blueColor or CFG.orangeColor
                p.Shape = Enum.PartType.Ball
                p.Size = Vector3.new(0.4, 0.4, 0.4); p.Transparency = 0.05
                p.CFrame = CFrame.new(hrp.Position + Vector3.new(ox, 0, oz))
                p.Parent = Workspace
                tw(p, 0.9, { Size = Vector3.new(9, 9, 9), Transparency = 1 })
                safeDelay(1.1, function() pcall(function() p:Destroy() end) end)
                safeWait(0.12)
            end

        elseif pw == "TimeSlow" then
            local r = Instance.new("Part")
            r.Anchored = true; r.CanCollide = false; r.CanTouch = false
            r.Material = Enum.Material.Neon; r.Color = Color3.fromRGB(100, 200, 255)
            r.Shape = Enum.PartType.Ball
            r.Size = Vector3.new(0.4, 0.4, 0.4); r.Transparency = 0.1
            r.CFrame = hrp.CFrame; r.Parent = Workspace
            tw(r, 1.6, { Size = Vector3.new(45, 45, 45), Transparency = 1 })
            safeDelay(1.8, function() pcall(function() r:Destroy() end) end)

        elseif pw == "Shield" then
            local hum = hrp.Parent and hrp.Parent:FindFirstChildOfClass("Humanoid")
            if hum then
                pcall(function() hum.Health = hum.MaxHealth end)
            end
        end
    end)
end

