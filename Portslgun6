    elseif kc == Enum.KeyCode.Q then placePortal("orange")
    elseif kc == Enum.KeyCode.Z then
        selColor = "blue"; crosshairLbl.Text = "● BLUE"; crosshairLbl.TextColor3 = CFG.blueColor
    elseif kc == Enum.KeyCode.X then
        selColor = "orange"; crosshairLbl.Text = "● ORANGE"; crosshairLbl.TextColor3 = CFG.orangeColor
    elseif kc == Enum.KeyCode.LeftBracket  then portalRotation = (portalRotation - 15) % 360
    elseif kc == Enum.KeyCode.RightBracket then portalRotation = (portalRotation + 15) % 360
    elseif kc == Enum.KeyCode.BackSlash    then portalRotation = 0; portalTilt = 0
    elseif kc == Enum.KeyCode.Semicolon    then portalTilt = (portalTilt - 15) % 360
    elseif kc == Enum.KeyCode.Quote        then portalTilt = (portalTilt + 15) % 360
    elseif kc == Enum.KeyCode.F            then triggerReload()
    end
end)

