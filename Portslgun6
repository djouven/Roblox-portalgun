-- Slow breathing pulse: ring/halo gently scale + glow in and out while a
-- portal stays open, so it never looks like a static decal.
function VFX.portalBreathe(portalData, color)
    if not portalData or not portalData.folder then return end
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local baseHaloTr = portalData.halo.Transparency
    local baseLight  = portalData.light.Brightness
    safeSpawn(function()
        local t = 0
        while portalData.folder and portalData.folder.Parent do
            t = t + 0.06
            local wave = math.sin(t * 1.6)
            pcall(function()
                portalData.halo.Transparency = math.clamp(baseHaloTr + wave * 0.10, 0, 1)
                portalData.light.Brightness  = math.max(0.15, baseLight + wave * (baseLight * 0.25))
                portalData.light.Color       = col
            end)
            safeWait(0.06)
        end
    end)
end

-- A handful of small sparks that continuously orbit the rim of the portal,
-- independent from the one-shot emitter burst used on open.
function VFX.orbitalSparks(portalData, color)
    if not portalData or not portalData.part then return end
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local sparkCount = 3
    local sparks = {}
    for i = 1, sparkCount do
        local s = Instance.new("Part")
        s.Name = "VFX_OrbitalSpark"; s.Shape = Enum.PartType.Ball
        s.Anchored = true; s.CanCollide = false; s.CanTouch = false; s.CastShadow = false
        s.Material = Enum.Material.Neon; s.Color = col
        s.Size = Vector3.new(0.16, 0.16, 0.16)
        s.Parent = portalData.folder
        sparks[i] = s
    end
    safeSpawn(function()
        local t = 0
        while portalData.folder and portalData.folder.Parent do
            t = t + 0.045
            local cf = portalData.part.CFrame
            local rw = (CFG.portalWidth  * 0.5) * 0.92
            local rh = (CFG.portalHeight * 0.5) * 0.92
            for i, s in ipairs(sparks) do
                local ang = t * 1.4 + (i - 1) * (math.pi * 2 / sparkCount)
                local localPos = Vector3.new(math.cos(ang) * rw, math.sin(ang) * rh, 0.05)
                pcall(function() s.CFrame = cf * CFrame.new(localPos) end)
            end
            safeWait(0.045)
        end
        for _, s in ipairs(sparks) do pcall(function() s:Destroy() end) end
    end)
end

-- Iris-blade style opening: thin wedge parts rotate inward from the rim
-- toward the center as the portal appears, like a camera aperture closing
-- around the screen instead of just scaling up.
function VFX.irisOpen(portalData, cf, color)
    if not portalData or not portalData.part then return end
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local bladeCount = 6
    local radius = math.max(CFG.portalWidth, CFG.portalHeight) * 0.62
    for i = 1, bladeCount do
        local blade = Instance.new("Part")
        blade.Name = "VFX_IrisBlade"; blade.Anchored = true
        blade.CanCollide = false; blade.CanTouch = false; blade.CastShadow = false
        blade.Material = Enum.Material.Neon; blade.Color = col; blade.Transparency = 0.15
        blade.Size = Vector3.new(0.08, radius * 0.9, 0.05)
        local ang = (i - 1) * (math.pi * 2 / bladeCount)
        local startPos = Vector3.new(math.cos(ang) * radius * 1.4, math.sin(ang) * radius * 1.4, 0.02)
        blade.CFrame = cf * CFrame.new(startPos) * CFrame.Angles(0, 0, ang)
        blade.Parent = portalData.folder
        tw(blade, CFG.openTime * 0.9, {
            CFrame = cf * CFrame.new(Vector3.new(0, 0, 0.02)) * CFrame.Angles(0, 0, ang + math.pi * 0.6),
            Transparency = 1,
        })
        vfxScheduleCleanup(blade, CFG.openTime + 0.3)
    end
end

