-- Subtle, continuous CFrame wobble so an open portal reads as an unstable
-- energy field rather than a perfectly rigid decal — imperceptible per
-- frame but noticeable over a few seconds.
function VFX.portalWobble(portalData, baseCF)
    if not portalData or not portalData.folder then return end
    safeSpawn(function()
        local t = 0
        while portalData.folder and portalData.folder.Parent do
            t = t + 0.05
            local wobX = math.sin(t * 2.2) * 0.015
            local wobY = math.cos(t * 1.7) * 0.015
            pcall(function() setPortalCFrames(portalData, baseCF * CFrame.new(wobX, wobY, 0)) end)
            safeWait(0.05)
        end
    end)
end

-- ─────────────────────────────────────────────────────────────────────
--  ANIMATION PACK II — heavier open/close choreography, idle motion loops
--  and extra teleport flourish. Every effect here is purely visual and
--  gated by its own CFG flag, same convention as the pack above.
-- ─────────────────────────────────────────────────────────────────────

-- Several thin rings pulse outward from the portal face in a staggered
-- cascade right as it opens, each one dimmer and slower than the last,
-- so the open reads as a "ripple burst" rather than one single ring.
function VFX.pulseRingCascade(cf, color)
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local waveCount = 4
    for i = 1, waveCount do
        safeDelay((i - 1) * 0.09, function()
            local ring = Instance.new("Part")
            ring.Name = "VFX_PulseCascadeRing"; ring.Anchored = true
            ring.CanCollide = false; ring.CanTouch = false; ring.CastShadow = false
            ring.Material = Enum.Material.Neon; ring.Color = col
            ring.Shape = Enum.PartType.Cylinder
            ring.Size = Vector3.new(0.04, 0.25, 0.25)
            ring.CFrame = cf * CFrame.Angles(0, 0, math.rad(90))
            ring.Transparency = 0.15 + (i - 1) * 0.08
            ring.Parent = Workspace
            local growTo = CFG.portalWidth * (1.1 + i * 0.35)
            tw(ring, 0.5 + i * 0.05, {
                Size = Vector3.new(0.04, growTo, growTo),
                Transparency = 1,
            })
            vfxScheduleCleanup(ring, 0.7 + i * 0.05)
        end)
    end
end

-- A ring of small rune-like wedges that stays attached to the portal rim
-- and slowly rotates as one unit for as long as the portal is open —
-- reads as an ancient/sci-fi "containment seal" rather than loose sparks.
function VFX.rotatingRunes(portalData, color)
    if not portalData or not portalData.part then return end
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local runeCount = 8
    local runes = {}
    local radius = math.max(CFG.portalWidth, CFG.portalHeight) * 0.58
    for i = 1, runeCount do
        local rune = Instance.new("Part")
        rune.Name = "VFX_Rune"; rune.Anchored = true
        rune.CanCollide = false; rune.CanTouch = false; rune.CastShadow = false
        rune.Material = Enum.Material.Neon; rune.Color = col; rune.Transparency = 0.25
        rune.Size = Vector3.new(0.06, 0.32, 0.1)
        rune.Parent = portalData.folder
        runes[i] = rune
    end
    safeSpawn(function()
        local t = 0
        while portalData.folder and portalData.folder.Parent do
            t = t + 0.04
            local cf = portalData.part.CFrame
            for i, rune in ipairs(runes) do
                local ang = t * 0.5 + (i - 1) * (math.pi * 2 / runeCount)
                local localPos = Vector3.new(math.cos(ang) * radius, math.sin(ang) * radius, 0.04)
                pcall(function()
                    rune.CFrame = cf * CFrame.new(localPos) * CFrame.Angles(0, 0, ang + math.pi / 2)
                end)
            end
            safeWait(0.04)
        end
        for _, rune in ipairs(runes) do pcall(function() rune:Destroy() end) end
    end)
end

-- While the portal is open, its light/halo occasionally "glitches" — a
-- quick dip in brightness and opacity like a loose power connection —
-- instead of holding a perfectly steady glow the whole time.
function VFX.portalFlicker(portalData)
    if not portalData or not portalData.light then return end
    local baseBrightness = portalData.light.Brightness
    local baseHaloTr     = portalData.halo.Transparency
    safeSpawn(function()
        while portalData.folder and portalData.folder.Parent do
            safeWait(math.random(15, 40) / 10)
            if not (portalData.folder and portalData.folder.Parent) then break end
            pcall(function()
                portalData.light.Brightness = baseBrightness * 0.25
                portalData.halo.Transparency = math.clamp(baseHaloTr + 0.35, 0, 1)
            end)
            safeWait(0.045)
            pcall(function()
                portalData.light.Brightness = baseBrightness
                portalData.halo.Transparency = baseHaloTr
            end)
        end
    end)
end

-- A single flat "radar ping" disc that expands along the portal's own
-- face plane the moment it opens — distinct from the cascading rings
-- above, this is one clean sonar-style sweep with an outline.
function VFX.portalPulseWave(cf, color)
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local disc = Instance.new("Part")
    disc.Name = "VFX_PulseWave"; disc.Anchored = true
    disc.CanCollide = false; disc.CanTouch = false; disc.CastShadow = false
    disc.Material = Enum.Material.Neon; disc.Color = col; disc.Transparency = 0.55
    disc.Size = Vector3.new(0.15, 0.15, 0.05)
    disc.CFrame = cf * CFrame.new(0, 0, -0.01)
    disc.Parent = Workspace
    local mesh = Instance.new("SpecialMesh")
    mesh.MeshType = Enum.MeshType.Sphere; mesh.Scale = Vector3.new(1, 1, 0.03); mesh.Parent = disc
    tw(disc, 0.4, {
        Size = Vector3.new(CFG.portalWidth * 1.6, CFG.portalHeight * 1.6, 0.05),
        Transparency = 1,
    })
    vfxScheduleCleanup(disc, 0.5)
end

-- When both portals exist, a quick traveling bolt visually links them —
-- a thin beam that stretches from the newly-placed portal to the other
-- one and fades, selling the idea that they're now "connected".
function VFX.chainReactionPulse(fromCF, toCF, color)
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local dist = (toCF.Position - fromCF.Position).Magnitude
    if dist < 0.5 then return end
    local mid = fromCF.Position:Lerp(toCF.Position, 0.5)
    local beam = Instance.new("Part")
    beam.Name = "VFX_ChainBeam"; beam.Anchored = true
    beam.CanCollide = false; beam.CanTouch = false; beam.CastShadow = false
    beam.Material = Enum.Material.Neon; beam.Color = col; beam.Transparency = 0.35
    beam.Size = Vector3.new(0.08, 0.08, dist)
    beam.CFrame = CFrame.new(mid, toCF.Position)
    beam.Parent = Workspace
    tw(beam, 0.3, {Transparency = 1})
    vfxScheduleCleanup(beam, 0.4)
    safeDelay(0.28, function()
        local arrival = Instance.new("Part")
        arrival.Anchored = true; arrival.CanCollide = false; arrival.CanTouch = false
        arrival.CastShadow = false; arrival.Material = Enum.Material.Neon; arrival.Color = col
        arrival.Shape = Enum.PartType.Ball; arrival.Size = Vector3.new(0.2, 0.2, 0.2)
        arrival.Transparency = 0.1; arrival.CFrame = toCF; arrival.Parent = Workspace
        tw(arrival, 0.3, {Size = Vector3.new(2, 2, 2), Transparency = 1})
        vfxScheduleCleanup(arrival, 0.4)
    end)
end

-- Adds a small elastic "overshoot" bounce right at the tail end of the
-- normal open tween — the portal grows slightly past full size then
-- settles back, instead of easing straight to its final scale.
function VFX.growIn(portalData, cf)
    if not portalData or not portalData.part then return end
    local pw, ph, pd = CFG.portalWidth, CFG.portalHeight, CFG.portalDepth
    safeDelay(CFG.openTime, function()
        if not (portalData.folder and portalData.folder.Parent) then return end
        pcall(function()
            tw(portalData.part,    0.12, {Size = Vector3.new(pw * 1.12, ph * 1.12, pd)})
            tw(portalData.shimmer, 0.12, {Size = Vector3.new(pw * 1.00, ph * 1.00, pd)})
        end)
        safeDelay(0.12, function()
            if not (portalData.folder and portalData.folder.Parent) then return end
            pcall(function()
                tw(portalData.part,    0.14, {Size = Vector3.new(pw, ph, pd)})
                tw(portalData.shimmer, 0.14, {Size = Vector3.new(pw * 0.90, ph * 0.90, pd)})
            end)
        end)
    end)
end

-- Faint vertical distortion columns near the base of the portal that
-- slowly drift upward and loop, like heat haze — pure ambient motion
-- meant to be seen out of the corner of the eye, not stared at directly.
function VFX.heatShimmer(portalData, cf, color)
    if not portalData or not portalData.folder then return end
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local columns = {}
    for i = 1, 3 do
        local c = Instance.new("Part")
        c.Name = "VFX_HeatShimmer"; c.Anchored = true
        c.CanCollide = false; c.CanTouch = false; c.CastShadow = false
        c.Material = Enum.Material.ForceField; c.Color = col; c.Transparency = 0.85
        c.Size = Vector3.new(0.5, 0.05, 0.1)
        c.Parent = portalData.folder
        columns[i] = c
    end
    safeSpawn(function()
        local t = 0
        while portalData.folder and portalData.folder.Parent do
            t = t + 0.06
            local basePos = cf.Position - Vector3.new(0, CFG.portalHeight * 0.5, 0)
            for i, c in ipairs(columns) do
                local phase = (t * 0.6 + (i - 1) * 0.6) % 1.4
                local xOff = (i - 2) * (CFG.portalWidth * 0.28)
                pcall(function()
                    c.CFrame = CFrame.new(basePos + Vector3.new(xOff, phase * 1.6, 0.05))
                    c.Transparency = math.clamp(0.85 + math.sin(phase * math.pi) * 0.1, 0.6, 0.98)
                end)
            end
            safeWait(0.06)
        end
        for _, c in ipairs(columns) do pcall(function() c:Destroy() end) end
    end)
end

-- Occasionally, at a random interval, the portal quickly "blinks" — the
-- screen briefly narrows to a sliver and reopens, like an eye — a rare
-- idle flourish so a portal left open for a while doesn't look static.
function VFX.portalEyeBlink(portalData)
    if not portalData or not portalData.screen then return end
    local baseSize = portalData.screen.Size
    safeSpawn(function()
        while portalData.folder and portalData.folder.Parent do
            safeWait(math.random(45, 110) / 10)
            if not (portalData.folder and portalData.folder.Parent) then break end
            pcall(function() tw(portalData.screen, 0.07, {Size = Vector3.new(baseSize.X, 0.06, baseSize.Z)}) end)
            safeWait(0.08)
            pcall(function() tw(portalData.screen, 0.1, {Size = baseSize}) end)
        end
    end)
end

-- Right before a portal is torn down, its ambient sparks and rim glow
-- get pulled inward and shrink into the centre instead of just cutting
-- out, so closing reads as "collapsing" rather than "disappearing".
function VFX.energyDrainSwirl(portalData, color)
    if not portalData or not portalData.part then return end
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local cf  = portalData.part.CFrame
    local motes = {}
    for i = 1, 6 do
        local m = Instance.new("Part")
        m.Name = "VFX_DrainMote"; m.Anchored = true; m.Shape = Enum.PartType.Ball
        m.CanCollide = false; m.CanTouch = false; m.CastShadow = false
        m.Material = Enum.Material.Neon; m.Color = col
        m.Size = Vector3.new(0.12, 0.12, 0.12)
        local ang = (i - 1) * (math.pi * 2 / 6)
        local rw, rh = CFG.portalWidth * 0.55, CFG.portalHeight * 0.55
        m.CFrame = cf * CFrame.new(math.cos(ang) * rw, math.sin(ang) * rh, 0.05)
        m.Parent = Workspace
        motes[i] = m
        tw(m, 0.35, {CFrame = cf, Size = Vector3.new(0.02, 0.02, 0.02), Transparency = 1})
        vfxScheduleCleanup(m, 0.45)
    end
end

-- A handful of short streak lines flick out behind the player in their
-- direction of travel the instant they exit a portal, selling a sense
-- of speed on top of the velocity boost already applied.
function VFX.speedLines(hrp, color)
    if not hrp then return end
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local vel = hrp.AssemblyLinearVelocity
    local dir = vel.Magnitude > 0.5 and vel.Unit or hrp.CFrame.LookVector
    for i = 1, 5 do
        local streak = Instance.new("Part")
        streak.Name = "VFX_SpeedLine"; streak.Anchored = true
        streak.CanCollide = false; streak.CanTouch = false; streak.CastShadow = false
        streak.Material = Enum.Material.Neon; streak.Color = col; streak.Transparency = 0.3
        streak.Size = Vector3.new(0.05, 0.05, 1.4 + math.random() * 0.8)
        local offset = Vector3.new((math.random() - 0.5) * 2.5, (math.random() - 0.3) * 2, (math.random() - 0.5) * 2.5)
        streak.CFrame = CFrame.new(hrp.Position + offset, hrp.Position + offset - dir)
        streak.Parent = Workspace
        tw(streak, 0.22, {Transparency = 1, CFrame = streak.CFrame - dir * 6})
        vfxScheduleCleanup(streak, 0.3)
    end
end

-- A tiny physical "landing hop" right after teleporting — a small kick
-- of upward and forward velocity so touching down on the other side
-- feels springy instead of the player just sliding out flat-footed.
function VFX.reboundBounce(hrp)
    if not hrp then return end
    pcall(function()
        local look = hrp.CFrame.LookVector
        hrp.AssemblyLinearVelocity = hrp.AssemblyLinearVelocity + Vector3.new(0, 6, 0) + look * 2
    end)
end

-- A quick, small camera roll right on teleport — not a full disorienting
-- spin, just a snappy tilt-and-settle that reads as a camera "flinch"
-- reacting to the sudden displacement.
function VFX.orbitCameraTilt()
    safeSpawn(function()
        local steps, dt = 8, 0.02
        for i = 1, steps do
            local amt = math.sin((i / steps) * math.pi) * math.rad(4)
            pcall(function() Cam.CFrame = Cam.CFrame * CFrame.Angles(0, 0, amt * ((i <= steps/2) and 1 or -1)) end)
            safeWait(dt)
        end
    end)
end

-- Attaches a short-lived Trail between the player's shoulders during the
-- exit motion, so there's a soft coloured ribbon following the whole
-- body for a moment rather than just a particle burst at one point.
function VFX.trailRibbon(hrp, color, duration)
    if not hrp then return end
    local char = hrp.Parent; if not char then return end
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local a0 = Instance.new("Attachment"); a0.Position = Vector3.new(-0.6, 1, 0); a0.Parent = hrp
    local a1 = Instance.new("Attachment"); a1.Position = Vector3.new(0.6, 1, 0);  a1.Parent = hrp
    local trail = Instance.new("Trail")
    trail.Attachment0 = a0; trail.Attachment1 = a1
    trail.Color = ColorSequence.new(col)
    trail.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0.2),NumberSequenceKeypoint.new(1,1)})
    trail.Lifetime = 0.4; trail.WidthScale = NumberSequence.new(1, 0)
    trail.Parent = hrp
    safeDelay(duration or 0.35, function()
        trail.Enabled = false
        safeDelay(0.5, function()
            pcall(function() trail:Destroy() end)
            pcall(function() a0:Destroy() end)
            pcall(function() a1:Destroy() end)
        end)
    end)
end

-- Two faint, slightly-offset colour "ghosts" of the player pop out and
-- separate briefly on teleport, mimicking a chromatic-aberration
-- afterimage rather than a plain motion blur.
function VFX.colorSplitAfterimage(hrp)
    if not hrp then return end
    local offsets = {
        {dir = Vector3.new(0.12, 0, 0),  color = Color3.fromRGB(255, 70, 70)},
        {dir = Vector3.new(-0.12, 0, 0), color = Color3.fromRGB(70, 200, 255)},
    }
    for _, o in ipairs(offsets) do
        local ghost = Instance.new("Part")
        ghost.Name = "VFX_ChromaGhost"; ghost.Anchored = true
        ghost.CanCollide = false; ghost.CanTouch = false; ghost.CastShadow = false
        ghost.Material = Enum.Material.ForceField; ghost.Color = o.color
        ghost.Transparency = 0.45; ghost.Size = Vector3.new(2, 5, 2)
        ghost.CFrame = hrp.CFrame + o.dir
        ghost.Parent = Workspace
        tw(ghost, 0.2, {Transparency = 1, CFrame = ghost.CFrame + o.dir * 3})
        vfxScheduleCleanup(ghost, 0.3)
    end
end

-- A brief camera FOV "punch" on exit — zooms in a few degrees then eases
-- back out to normal, giving teleporting a small cinematic snap without
-- affecting where the camera is actually looking.
function VFX.exitZoomPunch()
    if not Cam then return end
    local baseFov = Cam.FieldOfView
    pcall(function() Cam.FieldOfView = baseFov - 6 end)
    safeDelay(0.05, function()
        safeSpawn(function()
            local steps, dt = 6, 0.02
            for i = 1, steps do
                pcall(function() Cam.FieldOfView = baseFov - 6 + (6 * i / steps) end)
                safeWait(dt)
            end
            pcall(function() Cam.FieldOfView = baseFov end)
        end)
    end)
end

-- Right as a teleport begins, the entry portal (the one being left
-- behind) flashes brighter for an instant, like it just discharged the
-- energy needed to send the player through.
function VFX.teleportWindupFlash(fromData, color)
    if not fromData or not fromData.light then return end
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local baseBrightness = fromData.light.Brightness
    pcall(function()
        fromData.light.Brightness = baseBrightness * 3
        fromData.light.Color = col
    end)
    safeDelay(0.08, function()
        pcall(function() tw(fromData.light, 0.25, {Brightness = baseBrightness}) end)
    end)
end

-- The whole portal face slowly rolls in place while it's open — not the
-- rim decorations, the actual ring/shimmer meshes rotating around their
-- own look-axis — so light catches the neon surface differently over
-- time instead of it reading as one flat, unmoving sheet.
function VFX.portalRingSpin(portalData, baseCF)
    if not portalData or not portalData.part then return end
    safeSpawn(function()
        local roll = 0
        while portalData.folder and portalData.folder.Parent do
            roll = roll + math.rad(6)
            pcall(function()
                local spun = baseCF * CFrame.Angles(0, 0, roll)
                portalData.shimmer.CFrame = spun * CFrame.new(0, 0, -0.02)
                portalData.halo.CFrame    = spun * CFrame.new(0, 0, -0.06)
            end)
            safeWait(0.08)
        end
    end)
end

-- A handful of small tumbling rock/debris chunks drift in a slow, wide
-- orbit around an open portal — heavier and slower than the orbital
-- sparks, reading as loose matter caught in the portal's pull rather
-- than pure energy.
function VFX.floatingDebrisOrbit(portalData, color)
    if not portalData or not portalData.part then return end
    local debrisCount = 3
    local chunks = {}
    local radius = math.max(CFG.portalWidth, CFG.portalHeight) * 1.05
    for i = 1, debrisCount do
        local chunk = Instance.new("Part")
        chunk.Name = "VFX_OrbitDebris"; chunk.Anchored = true
        chunk.CanCollide = false; chunk.CanTouch = false; chunk.CastShadow = false
        chunk.Material = Enum.Material.Slate; chunk.Color = Color3.fromRGB(90, 85, 80)
        chunk.Size = Vector3.new(0.25, 0.2, 0.22)
        chunk.Parent = portalData.folder
        chunks[i] = chunk
    end
    safeSpawn(function()
        local t = math.random() * 10
        while portalData.folder and portalData.folder.Parent do
            t = t + 0.05
            local cf = portalData.part.CFrame
            for i, chunk in ipairs(chunks) do
                local ang = t * 0.35 + (i - 1) * (math.pi * 2 / debrisCount)
                local wob = math.sin(t * 2 + i) * 0.1
                local localPos = Vector3.new(math.cos(ang) * radius, math.sin(ang) * radius * 0.7 + wob, 0.3)
                pcall(function()
                    chunk.CFrame = cf * CFrame.new(localPos) * CFrame.Angles(t * 0.6, t * 0.4, t * 0.5)
                end)
            end
            safeWait(0.05)
        end
        for _, chunk in ipairs(chunks) do pcall(function() chunk:Destroy() end) end
    end)
end

-- A decaying camera shake specifically tied to placing a portal — a
-- much smaller jolt than the teleport shake, just enough to sell that
-- the shot landed with some force before the portal settles open.
function VFX.cameraShakeRipple(strength)
    safeSpawn(function()
        local steps, dt = 6, 0.02
        for i = 1, steps do
            local s = (strength or 0.15) * (1 - i / steps)
            pcall(function()
                Cam.CFrame = Cam.CFrame * CFrame.new(
                    (math.random() - 0.5) * 2 * s, (math.random() - 0.5) * 2 * s, 0)
            end)
            safeWait(dt)
        end
    end)
end

-- Over the course of the open tween, the portal ring fades in from a
-- near-white flash toward its true colour instead of being fully
-- coloured the instant it appears — a small "charging up" gradient.
function VFX.portalColorBleed(portalData, color)
    if not portalData or not portalData.part then return end
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local white = Color3.new(1, 1, 1)
    pcall(function()
        portalData.part.Color    = white
        portalData.shimmer.Color = white
    end)
    tw(portalData.part,    CFG.openTime * 0.8, {Color = col})
    tw(portalData.shimmer, CFG.openTime * 0.8, {Color = col})
end

-- A ring bursts outward from the exact spot a player lands after
-- teleporting, on the destination portal's face — separate from the
-- muzzle shock ring, which only ever plays at the moment a portal is
-- fired, not when someone arrives through an existing one.
function VFX.arrivalBurstRing(toCF, color)
    if not toCF then return end
    local col = color == "blue" and CFG.blueColor or CFG.orangeColor
    local ring = Instance.new("Part")
    ring.Name = "VFX_ArrivalBurst"; ring.Anchored = true
    ring.CanCollide = false; ring.CanTouch = false; ring.CastShadow = false
    ring.Material = Enum.Material.Neon; ring.Color = col
    ring.Shape = Enum.PartType.Cylinder
    ring.Size = Vector3.new(0.05, 0.3, 0.3)
    ring.CFrame = toCF * CFrame.Angles(0, 0, math.rad(90)) * CFrame.new(0, 0, 0.05)
    ring.Transparency = 0.1
    ring.Parent = Workspace
    tw(ring, 0.3, {
        Size = Vector3.new(0.05, CFG.portalWidth * 2.2, CFG.portalHeight * 2.2),
        Transparency = 1,
    })
    vfxScheduleCleanup(ring, 0.4)

    -- A second, faster inner ring gives the burst some depth instead of
    -- reading as one flat expanding disc.
    local innerRing = Instance.new("Part")
    innerRing.Name = "VFX_ArrivalBurstInner"; innerRing.Anchored = true
    innerRing.CanCollide = false; innerRing.CanTouch = false; innerRing.CastShadow = false
    innerRing.Material = Enum.Material.Neon; innerRing.Color = Color3.new(1, 1, 1)
    innerRing.Shape = Enum.PartType.Cylinder
    innerRing.Size = Vector3.new(0.04, 0.15, 0.15)
    innerRing.CFrame = toCF * CFrame.Angles(0, 0, math.rad(90)) * CFrame.new(0, 0, 0.06)
    innerRing.Transparency = 0.2
    innerRing.Parent = Workspace
    tw(innerRing, 0.18, {
        Size = Vector3.new(0.04, CFG.portalWidth * 1.1, CFG.portalHeight * 1.1),
        Transparency = 1,
    })
    vfxScheduleCleanup(innerRing, 0.25)
end

