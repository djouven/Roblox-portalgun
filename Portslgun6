local fireCooldown   = false
local recoilT        = 0     -- seconds of recoil kick remaining
local recoilDur      = 0.22  -- length of the *current* recoil, set per-shot from SHOOT_MODES
local recoilMul      = 1.0   -- kick strength multiplier for the current shot's SHOOT_MODES entry
local reloadActive   = false
local reloadProgress = 0
